@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix flo:   <https://ontology.kosm.io/floriscore/ref#> .
@prefix cccev: <http://data.europa.eu/m8g/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#  PROFIL APPLICATIF FLORISCORE  contraintes SHACL d'ingestion
#  Valide tout référentiel chargé dans l'ontologie.
#  Généralisable : remplacer flo: par std: pour le socle générique.
#################################################################

flo:ReferentielShape a sh:NodeShape ;
    sh:targetClass flo:Referentiel ;
    sh:property [ sh:path dct:title ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un référentiel doit avoir un titre (dct:title)." ] ;
    sh:property [ sh:path dct:publisher ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "Un référentiel devrait déclarer son éditeur (dct:publisher)." ] .

flo:CritereCommunShape a sh:NodeShape ;
    sh:targetClass flo:CritereCommun ;
    sh:property [ sh:path skos:prefLabel ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un critère commun doit avoir un libellé (skos:prefLabel)." ] ;
    sh:property [ sh:path flo:aPourTheme ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un critère commun doit être rattaché à un thème (flo:aPourTheme)." ] .

flo:CritereReferentielShape a sh:NodeShape ;
    sh:targetClass flo:CritereReferentiel ;
    sh:property [ sh:path skos:prefLabel ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un critère doit avoir un libellé (skos:prefLabel)." ] ;
    sh:property [ sh:path cccev:isDerivedFrom ; sh:minCount 1 ; sh:class flo:Referentiel ; sh:severity sh:Violation ;
        sh:message "Un critère doit dériver d'un référentiel (cccev:isDerivedFrom -> flo:Referentiel)." ] ;
    sh:property [ sh:path flo:aPourTheme ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un critère doit porter un thème (flo:aPourTheme)." ] ;
    sh:property [ sh:path flo:aNiveauExigence ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "Un critère doit porter un niveau d'exigence (flo:aNiveauExigence)." ] ;
    sh:property [
        sh:path [ sh:alternativePath ( flo:aligneSur flo:equivautA flo:rapprocheDe flo:plusLargeQue flo:plusStrictQue ) ] ;
        sh:minCount 1 ; sh:class flo:CritereCommun ; sh:severity sh:Violation ;
        sh:message "Un critère doit être rapproché d'au moins un critère commun (aligneSur ou un degré qualifié)." ] .
