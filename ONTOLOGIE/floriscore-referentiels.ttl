@prefix flo:   <https://ontology.kosm.io/floriscore/ref#> .
@prefix cccev: <http://data.europa.eu/m8g/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix adms:  <http://www.w3.org/ns/adms#> .
@prefix org:   <http://www.w3.org/ns/org#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix vann:  <http://purl.org/vocab/vann/> .

#################################################################
#  ONTOLOGIE
#################################################################

<https://ontology.kosm.io/floriscore/ref>
    a owl:Ontology ;
    dct:title "Ontologie des référentiels horticoles alignée sur CCCEV"@fr ;
    dct:description """Extension formelle du Core Criterion and Core Evidence Vocabulary (CCCEV 2.2.0)
        pour modéliser des référentiels de certification et labels de la filière horticole
        (Florverde, Rainforest Alliance, Fairtrade, FlorEcuador, Plante Bleue...).
        L'ontologie conserve chaque référentiel global et ses critères propres, et introduit
        une couche de RAPPROCHEMENT (critères communs thématiques) permettant de relier
        les critères similaires entre référentiels via des relations de correspondance SKOS.
        Conçue pour le projet Floriscore (Kosmio)."""@fr ;
    dct:publisher <https://kosm.io/#org> ;
    dct:created "2026-06-22"^^xsd:date ;
    owl:versionInfo "0.1.0" ;
    vann:preferredNamespacePrefix "flo" ;
    vann:preferredNamespaceUri "https://ontology.kosm.io/floriscore/ref#" ;
    dct:conformsTo <http://data.europa.eu/m8g/> ;
    rdfs:seeAlso <https://semiceu.github.io/CCCEV/releases/2.2.0/> .

#################################################################
#  CLASSES — extension de CCCEV
#################################################################

flo:Referentiel
    a owl:Class ;
    rdfs:subClassOf cccev:ReferenceFramework ;
    rdfs:label "Référentiel"@fr , "Standard / Label scheme"@en ;
    rdfs:comment """Dispositif d'évaluation publié par une organisation (label, standard,
        certification) servant de cadre de référence contre lequel un exploitant est évalué.
        Spécialise cccev:ReferenceFramework et regroupe un ensemble de flo:CritereReferentiel."""@fr .

flo:Chapitre
    a owl:Class ;
    rdfs:subClassOf cccev:Requirement ;
    rdfs:label "Chapitre"@fr , "Section / Domain"@en ;
    rdfs:comment """Regroupement structurant interne à un référentiel (ex. « Droit du travail »,
        « Santé et sécurité au travail »). Spécialise cccev:Requirement et agrège des critères
        via cccev:hasRequirement."""@fr .

flo:CritereReferentiel
    a owl:Class ;
    rdfs:subClassOf cccev:Criterion ;
    rdfs:label "Critère de référentiel"@fr , "Scheme-specific criterion"@en ;
    rdfs:comment """Critère tel qu'il est formulé par un référentiel donné, avec son libellé,
        son niveau d'exigence et les preuves attendues propres à ce référentiel.
        C'est l'unité qui est rapprochée d'un flo:CritereCommun."""@fr .

flo:CritereCommun
    a owl:Class ;
    rdfs:subClassOf cccev:Criterion , skos:Concept ;
    rdfs:label "Critère commun"@fr , "Common (canonical) criterion"@en ;
    rdfs:comment """Critère canonique, indépendant d'un référentiel, constituant le socle de
        rapprochement. Plusieurs flo:CritereReferentiel issus de référentiels différents pointent
        vers un même flo:CritereCommun, ce qui matérialise leur similarité tout en préservant
        chaque formulation d'origine. Organisé en grille thématique SKOS."""@fr .

flo:Theme
    a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Thème"@fr , "Theme"@en ;
    rdfs:comment "Axe thématique de la grille commune (gouvernance, social, environnement, etc.)."@fr .

flo:NiveauExigence
    a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Niveau d'exigence"@fr , "Compliance level"@en ;
    rdfs:comment "Statut d'un critère dans un référentiel (critique, majeur, mineur, recommandé...)."@fr .

flo:TypePreuve
    a owl:Class ;
    rdfs:subClassOf cccev:EvidenceType ;
    rdfs:label "Type de preuve"@fr , "Evidence type"@en ;
    rdfs:comment "Caractérisation d'une preuve attendue (document, registre, audit, mesure...). Spécialise cccev:EvidenceType."@fr .

flo:Preuve
    a owl:Class ;
    rdfs:subClassOf cccev:Evidence ;
    rdfs:label "Preuve"@fr , "Evidence"@en ;
    rdfs:comment "Élément concret fourni par un exploitant pour démontrer la conformité à un critère. Spécialise cccev:Evidence."@fr .

#################################################################
#  PROPRIÉTÉS D'OBJET
#################################################################

flo:definitCritere
    a owl:ObjectProperty ;
    rdfs:label "définit le critère"@fr ;
    rdfs:domain flo:Referentiel ;
    rdfs:range flo:CritereReferentiel ;
    owl:inverseOf cccev:isDerivedFrom ;
    rdfs:comment "Relie un référentiel aux critères qu'il définit (inverse de cccev:isDerivedFrom)."@fr .

flo:aPourTheme
    a owl:ObjectProperty ;
    rdfs:subPropertyOf dct:subject ;
    rdfs:label "a pour thème"@fr ;
    rdfs:range flo:Theme ;
    rdfs:comment "Rattache un critère (commun ou de référentiel) à un thème de la grille."@fr .

flo:aNiveauExigence
    a owl:ObjectProperty ;
    rdfs:label "a pour niveau d'exigence"@fr ;
    rdfs:domain flo:CritereReferentiel ;
    rdfs:range flo:NiveauExigence ;
    rdfs:comment "Indique le poids réglementaire du critère dans son référentiel."@fr .

flo:exigeTypePreuve
    a owl:ObjectProperty ;
    rdfs:label "exige un type de preuve"@fr ;
    rdfs:domain cccev:Criterion ;
    rdfs:range flo:TypePreuve ;
    rdfs:comment """Type de preuve attendu pour satisfaire le critère. Complète, au niveau de la
        définition, la relation cccev:supportsRequirement portée par les preuves concrètes."""@fr .

##### Couche de RAPPROCHEMENT (relations de correspondance) #####

flo:aligneSur
    a owl:ObjectProperty ;
    rdfs:subPropertyOf skos:mappingRelation ;
    rdfs:label "aligné sur"@fr ;
    rdfs:domain flo:CritereReferentiel ;
    rdfs:range flo:CritereCommun ;
    rdfs:comment """Relation générique de rapprochement d'un critère de référentiel vers un
        critère commun. Préciser le degré avec une des sous-propriétés ci-dessous."""@fr .

flo:equivautA
    a owl:ObjectProperty ;
    rdfs:subPropertyOf flo:aligneSur , skos:exactMatch ;
    rdfs:label "équivaut à"@fr ;
    rdfs:comment "Correspondance forte : le critère couvre exactement l'exigence du critère commun."@fr .

flo:rapprocheDe
    a owl:ObjectProperty ;
    rdfs:subPropertyOf flo:aligneSur , skos:closeMatch ;
    rdfs:label "proche de"@fr ;
    rdfs:comment "Correspondance partielle : exigences proches mais non strictement équivalentes."@fr .

flo:plusLargeQue
    a owl:ObjectProperty ;
    rdfs:subPropertyOf flo:aligneSur , skos:broadMatch ;
    rdfs:label "plus large que"@fr ;
    rdfs:comment "Le critère de référentiel couvre un périmètre plus large que le critère commun."@fr .

flo:plusStrictQue
    a owl:ObjectProperty ;
    rdfs:subPropertyOf flo:aligneSur , skos:narrowMatch ;
    rdfs:label "plus strict que"@fr ;
    rdfs:comment "Le critère de référentiel est plus exigeant / plus étroit que le critère commun."@fr .

#################################################################
#  PROPRIÉTÉS DE DONNÉES
#################################################################

flo:reference
    a owl:DatatypeProperty ;
    rdfs:label "référence interne"@fr ;
    rdfs:comment "Code / numéro du critère dans la checklist d'origine (ex. « 4.2.1 »)."@fr ;
    rdfs:range xsd:string .

flo:scoreFloriscore
    a owl:DatatypeProperty ;
    rdfs:subPropertyOf cccev:weight ;
    rdfs:label "score Floriscore"@fr ;
    rdfs:comment "Pondération attribuée au critère pour le calcul du score Floriscore."@fr ;
    rdfs:range xsd:decimal .

#################################################################
#  VOCABULAIRES CONTRÔLÉS (SKOS)
#################################################################


#################################################################
#  GRILLE THÉMATIQUE (étendue, 13 thèmes)
#################################################################

flo:GrilleCommune a skos:ConceptScheme ; dct:title "Grille des thèmes et critères communs Floriscore"@fr ;
    skos:hasTopConcept flo:thm-gouvernance , flo:thm-social , flo:thm-formation , flo:thm-sst , flo:thm-eau , flo:thm-sols , flo:thm-phyto , flo:thm-dechets , flo:thm-biodiversite , flo:thm-energie , flo:thm-intrants , flo:thm-qualite , flo:thm-tracabilite .

flo:thm-gouvernance a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Gouvernance et système de gestion"@fr .
flo:thm-social a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Droit du travail et conditions sociales"@fr .
flo:thm-formation a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Formation, entraînement et bien-être"@fr .
flo:thm-sst a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Santé et sécurité au travail"@fr .
flo:thm-eau a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Gestion et conservation de l'eau"@fr .
flo:thm-sols a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Sols, substrats et fertilisation"@fr .
flo:thm-phyto a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Contrôle phytosanitaire et usage des pesticides"@fr .
flo:thm-dechets a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Gestion des déchets"@fr .
flo:thm-biodiversite a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Paysage et biodiversité"@fr .
flo:thm-energie a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Énergie, maintenance et empreinte carbone"@fr .
flo:thm-intrants a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Origine du matériel végétal et intrants"@fr .
flo:thm-qualite a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Qualité et post-récolte"@fr .
flo:thm-tracabilite a flo:Theme ; skos:inScheme flo:GrilleCommune ; skos:prefLabel "Traçabilité, registres et transparence"@fr .

# Niveaux d'exigence (mappés sur les 3 niveaux Florverde)
flo:NiveauxExigence a skos:ConceptScheme ; dct:title "Niveaux d'exigence"@fr .
flo:niv-critique a flo:NiveauExigence ; skos:inScheme flo:NiveauxExigence ; skos:prefLabel "Niveau 1 (majeur / obligatoire)"@fr .
flo:niv-majeur a flo:NiveauExigence ; skos:inScheme flo:NiveauxExigence ; skos:prefLabel "Niveau 2 (intermédiaire)"@fr .
flo:niv-mineur a flo:NiveauExigence ; skos:inScheme flo:NiveauxExigence ; skos:prefLabel "Niveau 3 (mineur)"@fr .

