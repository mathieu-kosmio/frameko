# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=db.<project-id>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres

# Connexion directe (migrations, scripts en local). ATTENTION : l'endpoint direct
# db.<project-id>.supabase.co est IPv6 → injoignable depuis un hôte IPv4-only
# (VPS, conteneur). Pour ces environnements, mettre ici l'URL du SESSION pooler.
DATABASE_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
# Pooler (optionnel) — utilisé à la place de DATABASE_URL si USE_POOLER est activé
# (1/true/yes/on). En IPv4-only, utiliser le SESSION pooler (port 5432) : le
# transaction pooler (6543) est lui aussi IPv6 par défaut chez Supabase.
DATABASE_POOLER_URL=postgresql://postgres.<project-id>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
USE_POOLER=0

# Connexion applicative à moindre privilège (rôle frameko_app, soumis à la RLS).
# Générée par scripts/setup_app_role.py — utilisée pour les auto-évaluations.
# En IPv4-only, la mettre (ou APP_DATABASE_POOLER_URL) sur le Session pooler.
APP_DATABASE_URL=
APP_DATABASE_POOLER_URL=

# ── Auth / multi-organisation ───────────────────────────────────────────────
# Clé de signature des sessions web (sinon éphémère à chaque démarrage)
WEB_SECRET_KEY=
# Jeton d'organisation pour le serveur MCP en mode LOCAL/stdio (mono-organisation).
# En mode SaaS/HTTP, l'organisation est résolue par requête (header Authorization Bearer).
FRAMEKO_ORG_TOKEN=

# ── Serveur MCP (mode hébergé SaaS) ─────────────────────────────────────────
# stdio (défaut, local) ou http (service hébergé multi-tenant)
FRAMEKO_MCP_TRANSPORT=stdio
FRAMEKO_MCP_HOST=127.0.0.1
FRAMEKO_MCP_PORT=8765

# ── Embeddings (modèle local, aucune clé API) ───────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BACKEND=fastembed

# ── Ingestion IA (optionnel) ────────────────────────────────────────────────
# Approche par défaut : MCP-first (Claude via l'outil propose_mapping).
# La stack OpenAI ne sert qu'à l'ingestion batch autonome (scripts/ingest_framework.py --llm).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LOG_LEVEL=INFO
