# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=db.<project-id>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres

# Connexion directe (migrations, scripts, runtime par défaut)
DATABASE_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
# Pooler (optionnel) — confirmer la région exacte dans le tableau de bord Supabase.
# Activé seulement si USE_POOLER=1.
DATABASE_POOLER_URL=postgresql://postgres.<project-id>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
USE_POOLER=0

# ── Embeddings (modèle local, aucune clé API) ───────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BACKEND=fastembed

# ── Ingestion IA (optionnel) ────────────────────────────────────────────────
# Approche par défaut : MCP-first (Claude via l'outil propose_mapping).
# La stack OpenAI ne sert qu'à l'ingestion batch autonome (scripts/ingest_framework.py --llm).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LOG_LEVEL=INFO
